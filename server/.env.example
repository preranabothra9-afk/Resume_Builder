# === REQUIRED: Set these in your Render dashboard (or copy to .env for local dev) ===

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net
JWT_SECRET=<random-64-char-hex>
JWT_REFRESH_SECRET=<another-random-64-char-hex>
FRONTEND_URL=https://your-frontend.vercel.app

# === OPTIONAL ===

BACKEND_URL=https://your-backend.onrender.com
PORT=3000

# Email (Brevo SMTP)
BREVO_USER=your-brevo-smtp-user
BREVO_PASS=your-brevo-smtp-pass

# ImageKit
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key

# OpenAI / Gemini
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-3-flash-preview

# Admin
ADMIN_EMAIL=admin@example.com
